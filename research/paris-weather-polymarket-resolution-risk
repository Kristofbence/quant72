          <span style="font-family:var(--mono);font-size:10px;background:rgba(217,119,6,0.15);color:#fbbf24;border:1px solid rgba(217,119,6,0.3);border-radius:3px;padding:3px 8px">reported_anomalous_reading</span>
          <span style="font-family:var(--mono);font-size:10px;background:rgba(217,119,6,0.15);color:#fbbf24;border:1px solid rgba(217,119,6,0.3);border-radius:3px;padding:3px 8px">cross_venue_non_equivalence</span>
